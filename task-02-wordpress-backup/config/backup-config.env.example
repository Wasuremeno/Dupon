# ============================================
# Конфигурация для бэкапа WordPress
# ============================================

# ---------- Параметры сайта ----------
# Путь к корневой директории WordPress
SITE_PATH="/var/www/wordpress"

# Параметры базы данных
DB_NAME="wordpress_db"        # Имя базы данных
DB_USER="wp_user"             # Пользователь БД
DB_PASS="secure_password"     # Пароль пользователя БД
DB_HOST="localhost"           # Хост БД (обычно localhost)
DB_PORT="3306"                # Порт БД (обычно 3306)

# ---------- Параметры бэкапа ----------
# Директория для хранения бэкапов
BACKUP_DIR="/backups/wordpress"

# Сколько дней хранить бэкапы (ротация)
BACKUP_RETENTION_DAYS=7

# Максимальный размер бэкапа в MB (0 - без ограничений)
# Если бэкап больше, отправится предупреждение
MAX_BACKUP_SIZE_MB=0

# Исключения при копировании файлов (через пробел)
# Эти папки/файлы не попадут в бэкап
EXCLUDE_PATTERNS=(
    "wp-content/cache"
    "wp-content/uploads/cache"
    "wp-content/updraft"
    "*.log"
    "error_log"
    ".git"
    "node_modules"
    ".env"
)

# ---------- Telegram ----------
# Токен бота (получить у @BotFather)
TELEGRAM_TOKEN="1234567890:ABCdefGHIjklMNOpqrsTUVwxyz"

# ID чата для уведомлений (можно получить у @userinfobot)
CHAT_ID="123456789"

# Опционально: отдельный чат для критических ошибок
# Если не задан, ошибки уходят в основной CHAT_ID
ERROR_CHAT_ID="987654321"

# ---------- Опционально: уведомления по email ----------
# Если Telegram недоступен, можно настроить email
SMTP_SERVER=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
EMAIL_TO="admin@example.com"
EMAIL_FROM="backup@example.com"

# ---------- Опционально: загрузка в облако ----------
# AWS S3 (или совместимые: DigitalOcean Spaces, Yandex Cloud)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_DEFAULT_REGION="ru-central1"
S3_BUCKET="my-backups"
S3_PATH="wordpress/"

# ---------- Опционально: FTP ----------
FTP_HOST=""
FTP_USER=""
FTP_PASS=""
FTP_PATH="/backups/wordpress/"

# ---------- Дополнительные настройки ----------
# Сжатие (gzip, bzip2, xz)
COMPRESSION="gzip"

# Уровень сжатия (1-9, где 9 - максимальное)
COMPRESSION_LEVEL=6

# Отправлять ли отчет всегда (true) или только при ошибках (false)
ALWAYS_SEND_REPORT=true

# Дополнительные опции для mysqldump
# Например: "--single-transaction --quick"
MYSQLDUMP_OPTIONS="--single-transaction --quick --skip-lock-tables"

# Локальный лог-файл (если не задан, используется /var/log/wordpress-backup.log)
LOG_FILE="/var/log/wordpress-backup.log"

# ============================================
# Пример использования в скрипте:
# source /etc/wordpress-backup/config.env
# ============================================