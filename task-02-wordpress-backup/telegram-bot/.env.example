# Telegram Bot Token (получить у @BotFather)
TELEGRAM_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# ID чатов, которым разрешено использовать бота (через запятую)
ALLOWED_CHAT_IDS=123456789,987654321

# ID чатов администраторов (через запятую)
ADMIN_CHAT_IDS=123456789

# Директория с бэкапами на сервере
BACKUP_DIR=/backups/wordpress

# Интервал проверки в формате cron (по умолчанию каждые 6 часов)
CHECK_INTERVAL=0 */6 * * *

# Опционально: несколько серверов для мониторинга
# SERVERS=[{"host":"server1.example.com","username":"backup","password":"pass"},{"host":"server2.example.com","username":"backup","privateKey":"/home/user/.ssh/id_rsa"}]
SERVERS=[]

# Путь к лог-файлу
LOG_FILE=/var/log/wordpress-backup-bot.log